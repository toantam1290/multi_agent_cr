# =============================================================================
# BẮT BUỘC — Điền trước khi chạy
# =============================================================================

ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_DAILY_BUDGET_USD=0.75

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
# Khi true: chạy không cần Telegram (API bị chặn/timeout)
SKIP_TELEGRAM=false

# =============================================================================
# TRADING (có default)
# =============================================================================

PAPER_TRADING=true
PAPER_BALANCE_USDT=10000

# Pairs phân tích (fixed mode) hoặc fallback khi opportunity API lỗi
ALLOWED_PAIRS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT,DOGEUSDT,ADAUSDT,AVAXUSDT,DOTUSDT,LINKUSDT,LTCUSDT,NEARUSDT,APTUSDT,ARBUSDT,OPUSDT,SUIUSDT,INJUSDT,ATOMUSDT,TONUSDT,TRXUSDT

MAX_POSITION_PCT=0.01
MAX_DAILY_LOSS_PCT=0.05
MAX_OPEN_POSITIONS=30
MIN_CONFIDENCE=75
MIN_RISK_REWARD=2.0
APPROVAL_TIMEOUT_SEC=300

# Scalp override (khi TRADING_STYLE=scalp): confidence thấp hơn (match backtest), timeout ngắn
SCALP_MIN_CONFIDENCE=55
SCALP_APPROVAL_TIMEOUT_SEC=120
SCALP_RISK_REWARD_RATIO=1.5

# Funding filter: symmetric ±0.03% — block LONG khi > +0.03%, SHORT khi < -0.03%
# FUNDING_LONG_MAX_PCT=0.03
# FUNDING_SHORT_MIN_PCT=-0.03

# Scalp: whale context (1h), 1h range min %, active hours UTC (8-16 = EU+US overlap)
# SCALP_WHALE_HOURS=1
# SCALP_1H_RANGE_MIN_PCT=0.5
# SCALP_ACTIVE_HOURS_UTC=8-16

# Session filter: dead_zone skip, asia=core only. false để tắt
# SCALP_SESSION_FILTER=true

# RELAX_FILTER=true: nới filter để test pipeline (net_score 5/-5, bỏ volume/momentum/1h range). Chỉ dùng khi test!
# RELAX_FILTER=false

# EXTRA_SCALP_FILTERS: bật 6 live-only hard gates (F&G, spread, CVD divergence, VWAP bias, EMA9 timing)
# Mặc định OFF để live khớp với backtest. Set true nếu muốn strict hơn backtest.
EXTRA_SCALP_FILTERS=false

# =============================================================================
# OPPORTUNITY SCREENING (khi SCAN_MODE=opportunity)
# =============================================================================

# fixed = dùng ALLOWED_PAIRS cố định | opportunity = dynamic screening
SCAN_MODE=opportunity
TRADING_STYLE=scalp

# Volatility range: min <= |priceChange%| <= max (tránh pump & dump)
OPPORTUNITY_VOLATILITY_PCT=1.0
OPPORTUNITY_VOLATILITY_MAX_PCT=30.0

# Thanh khoản tối thiểu (USD)
MIN_QUOTE_VOLUME_USD=5000000

# Cap số cặp scan mỗi cycle (không phải target)
MAX_PAIRS_PER_SCAN=30

# Luôn scan (bypass volatility filter). Top 20 coins
CORE_PAIRS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT,DOGEUSDT,ADAUSDT,AVAXUSDT,DOTUSDT,LINKUSDT,LTCUSDT,NEARUSDT,APTUSDT,ARBUSDT,OPUSDT,SUIUSDT,INJUSDT,ATOMUSDT,TONUSDT,TRXUSDT

# Stablecoin blacklist
SCAN_BLACKLIST=USDCUSDT,BUSDUSDT,FDUSDUSDT,TUSDUSDT,DAIUSDT,USDTUSDT

# Khi true: opportunity_pairs = opportunity_pairs ∩ ALLOWED_PAIRS
OPPORTUNITY_USE_WHITELIST=false

# Chỉ log danh sách cặp, không chạy analyze_pair
SCAN_DRY_RUN=false

# auto = dùng BTC 24h change | manual = dùng MARKET_REGIME
MARKET_REGIME_MODE=auto
# Khi manual: sideways (confluence >= 2) | trend (confluence >= 1)
MARKET_REGIME=sideways

# Phase 1.5: Confluence + cooldown/hysteresis
COOLDOWN_CYCLES=2
CYCLE_INTERVAL_SEC=900
HYSTERESIS_ENTRY_PCT=5.0
HYSTERESIS_EXIT_PCT=3.0
FUNDING_EXTREME_THRESHOLD=0.001

# =============================================================================
# HTTP / Network (khi ConnectTimeout với Binance)
# =============================================================================

# Timeout mỗi request (giây). Mặc định 30. Tăng lên 45-60 nếu mạng chậm / VPN
HTTP_TIMEOUT_SEC=45

# =============================================================================
# Binance (chỉ cần khi PAPER_TRADING=false)
# =============================================================================

BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# =============================================================================
# Futures fee (Binance USDT-M): maker 0.02%, taker 0.04%
# Override nếu có VIP tier hoặc BNB discount
# =============================================================================
# MAKER_FEE_PCT=0.0002
# TAKER_FEE_PCT=0.0004

# =============================================================================
# Scalp advanced (thường không cần sửa)
# =============================================================================
SCAN_INTERVAL_MIN=5
POSITION_MONITOR_INTERVAL_MIN=1
SCALP_RSI_LONG_MAX=50
SCALP_RSI_SHORT_MIN=50

# Trade 24/24: tắt session filter, active mọi giờ
SCALP_ACTIVE_HOURS_UTC=0-23
SCALP_SESSION_FILTER=false
